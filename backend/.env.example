# ==================== Environment Configuration ====================
NODE_ENV=development
PORT=5000

# ==================== MongoDB Configuration ====================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>_test?retryWrites=true&w=majority

# ==================== Security Settings ====================
EMAIL_VERIFICATION_REQUIRED=true
PHONE_VERIFICATION_REQUIRED=false
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=30
SESSION_TIMEOUT=30

# ==================== Web Push (VAPID) ====================
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=support@yourdomain.com

# ==================== Session Secret ====================
SESSION_SECRET=your_strong_random_session_secret

# ==================== Frontend URL ====================
FRONTEND_URL=http://localhost:5173

# ==================== Email (SMTP) ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com

# ==================== Twilio (SMS) ====================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ==================== reCAPTCHA ====================
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_SCORE_THRESHOLD=0.5
SKIP_RECAPTCHA=false

# ==================== Stripe ====================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ==================== Cloudinary ====================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DISABLED=true

# ==================== Social Media OAuth ====================
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
YOUTUBE_API_KEY=your_youtube_api_key
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ==================== Rate Limiting ====================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ==================== Admin Defaults ====================
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_strong_admin_password

# ==================== Additional Social Media APIs ====================
RAPIDAPI_KEY=your_rapidapi_key
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# ==================== Encryption Key ====================
ENCRYPTION_KEY=your_base64_encoded_encryption_key

# ==================== JWT Configuration ====================
JWT_SECRET=your_strong_jwt_secret
JWT_REFRESH_SECRET=your_strong_jwt_refresh_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
