{
  "name": "influencex-backend",
  "version": "1.0.0",
  "description": "Backend API for InfluenceX - Influencer Deal Marketplace",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles --forceExit --config jest.config.js",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit",
    "test:2fa": "cross-env NODE_ENV=test jest tests/security/2fa.test.js --runInBand --detectOpenHandles --forceExit",
    "test:contract": "cross-env NODE_ENV=test jest tests/contracts --runInBand --detectOpenHandles --forceExit",
    "test:security": "cross-env NODE_ENV=test jest tests/security --runInBand --detectOpenHandles --forceExit",
    "debug": "nodemon --inspect server.js",
    "seed:admin": "node seeders/adminSeeder.js",
    "seed:qa": "node seeders/qaSeeder.js",
    "seed:fraud-flagged": "node seeders/fraudFlaggedCreatorSeeder.js",
    "seed:qa:test": "cross-env NODE_ENV=test node seeders/qaSeeder.js",
    "seed:production": "node seeders/run-seed.js all",
    "seed:production:clear": "node seeders/run-seed.js all --clear",
    "seed:users": "node seeders/run-seed.js users",
    "seed:campaigns": "node seeders/run-seed.js campaigns",
    "seed:clear": "node seeders/run-seed.js clear",
    "seed:verify": "node seeders/run-seed.js verify",
    "test:reg": "node scripts/test-registration.js",
    "test:load": "k6 run tests/load/k6-script.js",
    "test:load:smoke": "node -e \"require('fs').accessSync('tests/load/k6-script.js'); console.log('k6 script found')\"",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@bull-board/api": "^5.7.0",
    "@bull-board/express": "^5.7.0",
    "@google/generative-ai": "^0.24.1",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@sentry/node": "^10.46.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "agenda": "^5.0.0",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "cache-manager": "^5.2.3",
    "commander": "^11.1.0",
    "cache-manager-redis-yet": "^4.1.0",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.10.0",
    "express-status-monitor": "^1.3.4",
    "express-validator": "^7.0.1",
    "file-type": "^21.3.4",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "joi": "^17.10.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.5",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^3.0.1",
    "razorpay": "^2.9.6",
    "redis": "^4.7.1",
    "response-time": "^2.3.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^13.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.12.2",
    "uuid": "^9.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "cross-env": "^7.0.3",
    "jest": "^29.6.4",
    "jest-environment-node": "^29.7.0",
    "jest-mock": "^29.7.0",
    "mongodb-memory-server": "^9.1.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1"
  }
}
